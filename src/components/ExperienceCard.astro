---
interface Props {
  title: string;
  company: string;
  location: string;
  dates: string;
  bullets: string[];
  href?: string;
  detailHref?: string;
}

const { title, company, location, dates, bullets, href, detailHref } = Astro.props;
const Tag = detailHref ? "a" : "div";
---

<Tag class="experience-card" {...(detailHref ? { href: detailHref } : {})}>
  <div class="title-row">
    <h3>{title} &mdash; {company}</h3>
    <span class="dates">{dates}</span>
  </div>
  <span class="location">{location}</span>
  <ul>
    {bullets.map((b) => <li>{b}</li>)}
  </ul>
  {detailHref && <span class="read-more">Read more &rarr;</span>}
</Tag>

<style>
  .experience-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 3px solid var(--color-border);
    margin-bottom: 1rem;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
  }

  a.experience-card:hover {
    border-color: #d0d0d0;
    border-left-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  h3 {
    margin-bottom: 0;
  }

  .dates {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    font-weight: 500;
  }

  .location {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  ul {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
  }

  li {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
    line-height: 1.5;
  }

  .read-more {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .title-row {
      flex-direction: column;
      gap: 0.125rem;
    }
  }
</style>
