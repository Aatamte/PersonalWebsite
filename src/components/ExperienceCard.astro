---
interface Props {
  title: string;
  company: string;
  location: string;
  dates: string;
  bullets: string[];
}

const { title, company, location, dates, bullets } = Astro.props;
---

<div class="experience-card">
  <div class="header">
    <h3>{title} — {company}</h3>
    <span class="meta">{location} | {dates}</span>
  </div>
  <ul>
    {bullets.map((b) => <li>{b}</li>)}
  </ul>
</div>

<style>
  .experience-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .experience-card:last-child {
    border-bottom: none;
  }

  h3 {
    margin-bottom: 0.125rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  ul {
    margin-top: 0.5rem;
    padding-left: 1.25rem;
  }

  li {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
</style>
