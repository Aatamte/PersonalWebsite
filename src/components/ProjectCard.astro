---
interface Props {
  title: string;
  description: string;
  href?: string;
  tags?: string[];
}

const { title, description, href, tags } = Astro.props;
---

<div class="project-card">
  <h3>
    {href ? <a href={href} target="_blank" rel="noopener">{title}</a> : title}
  </h3>
  <p>{description}</p>
  {tags && tags.length > 0 && (
    <div class="tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</div>

<style>
  .project-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .project-card:last-child {
    border-bottom: none;
  }

  h3 {
    margin-bottom: 0.25rem;
  }

  p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }
</style>
