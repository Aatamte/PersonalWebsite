---
interface Props {
  items: { label: string; value: string }[];
}

const { items } = Astro.props;
---

<dl class="tech-stack">
  {items.map(({ label, value }) => (
    <div class="row">
      <dt>{label}</dt>
      <dd>{value}</dd>
    </div>
  ))}
</dl>

<style>
  .tech-stack {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .row {
    display: flex;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .row:last-child {
    border-bottom: none;
  }

  dt {
    font-weight: 600;
    font-size: 0.9rem;
    min-width: 140px;
    flex-shrink: 0;
  }

  dd {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .row {
      flex-direction: column;
      gap: 0.125rem;
    }
  }
</style>
