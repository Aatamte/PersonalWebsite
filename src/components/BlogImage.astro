---
const { src, alt } = Astro.props;
---

<figure>
  <img src={src} alt={alt} />
  {alt && <figcaption>{alt}</figcaption>}
</figure>

<style>
  figure {
    margin: 1.5rem 0;
    text-align: center;
  }

  img {
    max-width: 100%;
    width: 560px;
    height: auto;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  figcaption {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
