---
import Base from "./Base.astro";

interface Props {
  title: string;
  subtitle?: string;
  meta?: string;
  backHref: string;
  backLabel: string;
  externalHref?: string;
  externalLabel?: string;
}

const { title, subtitle, meta, backHref, backLabel, externalHref, externalLabel } = Astro.props;
---

<Base title={`${title} - Aaron Tamte`}>
  <a href={backHref} class="back">&larr; {backLabel}</a>
  <header>
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    {meta && <p class="meta">{meta}</p>}
    {externalHref && (
      <a href={externalHref} target="_blank" rel="noopener" class="external">
        {externalLabel || externalHref} &rarr;
      </a>
    )}
  </header>
  <div class="content">
    <slot />
  </div>
</Base>

<style>
  .back {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  header {
    margin-bottom: 2.5rem;
  }

  h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .meta {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .external {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .content :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }

  .content :global(li) {
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
    line-height: 1.6;
  }

  .content :global(strong) {
    color: var(--color-text);
  }

  .content :global(img) {
    display: block;
    max-width: 100%;
    width: 560px;
    height: auto;
    margin: 1.5rem auto;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
</style>
