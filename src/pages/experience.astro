---
import Base from "../layouts/Base.astro";
import ExperienceCard from "../components/ExperienceCard.astro";

const experience = [
  {
    title: "Founder & Engineer",
    company: "SheetOS",
    location: "Boston, MA",
    dates: "Dec 2024 – Present",
    bullets: [
      "Built an AI-powered data platform (sheetos.ai) as sole engineer — designed and shipped the full stack from scratch",
      "Architected a custom agentic framework in Go with multi-turn reasoning, 40+ dynamic context modules, tool orchestration, and sub-agent spawning",
      "Built real-time browser sync using ElectricSQL/PGlite (WASM Postgres in the browser) with WebSocket streaming",
      "Implemented multi-tenant isolation with per-workbook Postgres schemas and a reactive automation engine with DAG-based dependency tracking",
      "Developed a Python SDK (sheetos package) for sandboxed execution in isolated containers with full platform access",
    ],
  },
  {
    title: "Data Scientist",
    company: "Highwire Games",
    location: "Seattle, WA",
    dates: "June 2023 – Sept 2024",
    bullets: [
      "Sole data scientist — owned the full ML lifecycle with no DS manager or peers",
      "Built a graph neural network for predicting private user behavior from public social graph data across 60M+ user profiles",
      "Processed 1.6TB+ of gaming industry data through ETL pipelines via Apache Airflow and Spark across 20+ distributed containers",
      "Deployed end-to-end ML infrastructure on hybrid Proxmox/GCP with PostgreSQL and Neo4j",
      "Built a full-stack React analytics dashboard delivering competitive intelligence to non-technical leadership",
    ],
  },
];

const education = [
  {
    title: "MS in Artificial Intelligence",
    company: "Northeastern University",
    location: "Boston, MA",
    dates: "Sept 2024 – April 2026",
    bullets: ["GPA: 3.83/4.0"],
  },
  {
    title: "BA in Computer Science, Economics & Political Science",
    company: "St Olaf College",
    location: "Northfield, MN",
    dates: "Feb 2018 – Dec 2022",
    bullets: ["Triple major"],
  },
];
---

<Base title="Experience - Aaron Tamte" description="Aaron Tamte's professional experience and education">
  <h1>Experience</h1>
  {experience.map((exp) => <ExperienceCard {...exp} />)}

  <h2 class="section-header">Education</h2>
  {education.map((edu) => <ExperienceCard {...edu} />)}
</Base>

<style>
  h1 {
    margin-bottom: 1rem;
  }

  .section-header {
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
  }
</style>
