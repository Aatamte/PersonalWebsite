---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BlogPostCard from "../components/BlogPostCard.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = [
  {
    title: "SheetOS",
    description: "AI-powered data platform with a custom agentic framework in Go.",
    href: "https://sheetos.ai",
    tags: ["Go", "React", "LLMs"],
  },
  {
    title: "SLM-RL Search",
    description: "RL-trained 4B model for agentic code-based retrieval. 3.7x improvement over baseline.",
    href: "https://github.com/Aatamte/SLM-RL-Search",
    tags: ["RL", "vLLM", "Python"],
  },
  {
    title: "PyCxsim",
    description: "Open-source framework for simulating autonomous agents.",
    href: "https://github.com/Aatamte/PyCxsim",
    tags: ["Python", "Open Source"],
  },
];
---

<Base title="Aaron Tamte">
  <section class="bio">
    <h1>Aaron Tamte</h1>
    <p class="tagline">AI/ML Engineer</p>
    <p>
      MS in AI at Northeastern University. I build agent systems and ML
      infrastructure. Previously data scientist at Highwire Games.
    </p>
  </section>

  <section class="projects">
    <h2>Projects</h2>
    {projects.map((project) => <ProjectCard {...project} />)}
    <a href="/projects" class="see-all">All projects &rarr;</a>
  </section>

  <section class="blog">
    <h2>Recent Posts</h2>
    {posts.map((post) => (
      <BlogPostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        slug={post.id}
      />
    ))}
    <a href="/blog" class="see-all">All posts &rarr;</a>
  </section>
</Base>

<style>
  section {
    margin-bottom: 3rem;
  }

  .bio h1 {
    margin-bottom: 0.25rem;
  }

  .tagline {
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  h2 {
    margin-bottom: 0.5rem;
  }

  .see-all {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
  }
</style>
