---
import Base from "../layouts/Base.astro";

const documents = [
  {
    title: "Resume",
    description: "My current resume/CV.",
    href: "/documents/Resume.docx",
  },
];
---

<Base title="Documents - Aaron Tamte" description="Documents by Aaron Tamte">
  <h1>Documents</h1>
  <ul class="doc-list">
    {documents.map((doc) => (
      <li>
        <a href={doc.href} target="_blank" rel="noopener">{doc.title}</a>
        <p>{doc.description}</p>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 {
    margin-bottom: 1rem;
  }

  .doc-list {
    list-style: none;
  }

  .doc-list li {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .doc-list li:last-child {
    border-bottom: none;
  }

  .doc-list p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }
</style>
