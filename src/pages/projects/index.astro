---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = [
  {
    title: "SLM-RL Search",
    description: "Trained a 4B parameter model with RL to write and execute its own search strategies. 3.7x improvement over baseline.",
    slug: "slm-rl-search",
    tags: ["RL", "vLLM", "GRPO", "Python"],
  },
  {
    title: "Multi-Agent LLM Collaboration",
    description: "Multi-agent architecture with custom reflection and inter-agent communication. Fine-tuned LLaMA-3 8B with LoRA, 85% success rate across 7 coordination tasks.",
    slug: "multi-agent-llm",
    tags: ["LLaMA", "LoRA", "Multi-Agent", "HuggingFace"],
  },
  {
    title: "PyCxsim",
    description: "Open-source Python package for running multi-agent simulations with a real-time visual interface.",
    slug: "pycxsim",
    tags: ["Python", "Open Source", "Multi-Agent", "Simulation"],
  },
];
---

<Base title="Projects - Aaron Tamte" description="Projects by Aaron Tamte">
  <h1>Projects</h1>
  <div class="grid">
    {projects.map((project) => <ProjectCard {...project} detailHref={`/projects/${project.slug}`} />)}
  </div>
</Base>

<style>
  h1 {
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    gap: 1rem;
  }
</style>
