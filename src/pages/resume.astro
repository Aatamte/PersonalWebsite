---
import Base from "../layouts/Base.astro";
---

<Base title="Resume - Aaron Tamte" description="Aaron Tamte's resume">
  <div class="resume-header">
    <h1>Resume</h1>
    <a href="/documents/resume.pdf" download class="download-link">Download PDF &darr;</a>
  </div>
  <div class="pdf-viewer">
    <iframe src="/documents/resume.pdf" title="Resume"></iframe>
  </div>
</Base>

<style>
  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .download-link {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .pdf-viewer {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }

  iframe {
    width: 100%;
    height: 80vh;
    border: none;
    display: block;
  }
</style>
