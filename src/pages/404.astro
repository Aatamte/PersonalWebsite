---
import Base from "../layouts/Base.astro";
---

<Base title="Not Found - Aaron Tamte">
  <div class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist.</p>
    <a href="/">&larr; Back to home</a>
  </div>
</Base>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 0;
  }

  h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }

  a {
    font-weight: 500;
  }
</style>
